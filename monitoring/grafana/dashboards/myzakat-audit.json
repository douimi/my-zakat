        {
          "expr": "{container=~\".*backend.*\"} |= \"AUDIT\" |~ \"path=.*(/upload|/gallery|/slideshow|/events|/stories|/testimonials|/programs|/s3-media)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
