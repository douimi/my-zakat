    {
      "title": "Admin Actions by User",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (actor) (rate({container=~\".*backend.*\"} |= \"AUDIT\" |= \"role=admin\" | regexp \"actor=(?P<actor>\\\\S+)\" [5m]))",
          "legendFormat": "{{actor}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Actions by HTTP Method",
