      "targets": [
        {
          "expr": "sum by (method) (rate({container=~\".*backend.*\"} |= \"AUDIT\" | regexp \"method=(?P<method>\\\\S+)\" [5m]))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ]
