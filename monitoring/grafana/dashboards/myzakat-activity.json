{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "🔴 Live Activity",
      "description": "Everything happening right now. Look for names and actions like 'Omar: uploaded a new image'.",
      "type": "logs",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\".*backend.*\"} |~ \"✓|✗\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": false,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "❌ Problems (Errors & Failures)",
      "description": "Everything that failed. Check here when something looks wrong.",
      "type": "logs",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\".*backend.*\"} |~ \"✗|ERROR|Traceback\" != \"Skipping duplicate\" != \"INFO:\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": false,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "💳 Payments",
      "description": "Donations confirmed, subscriptions, certificates sent, Stripe webhooks.",
      "type": "logs",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\".*backend.*\"} |~ \"(?i)(donation confirmed|donation \\\\d+|certificate emailed|certificate auto|subscription activated|webhook.*(?:completed|succeeded|failed|expired|created|deleted)|recorded (?:abandoned|failed)|Processing webhook|started a (one-time|recurring)|canceled a subscription)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": false,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "🔐 Logins & Signups",
      "description": "Who logged in or registered recently.",
      "type": "logs",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\".*backend.*\"} |~ \"logged in|registered a new account\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": false,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "📤 Content Changes (Uploads / Edits / Deletes)",
      "description": "Uploads, edits, deletes across stories, events, gallery, testimonials, etc.",
      "type": "logs",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\".*backend.*\"} |~ \"(uploaded|created|updated|deleted|approved|reordered|resolved) a|✓ \\\\w+: (uploaded|created|updated|deleted|approved|reordered)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": false,
        "sortOrder": "Descending"
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["myzakat", "activity"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "MyZakat Activity",
  "uid": "myzakat-activity",
  "version": 2
}
